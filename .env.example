# MongoDB Atlas Connection
# Format: mongodb+srv://<username>:<password>@<cluster>.<mongo>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority

# Alternative environment variable names (any one will work)
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
# MONGODB_ATLAS_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority

# Database Configuration
MONGODB_DB_NAME=equipment_failure_db
MONGODB_COLLECTION_NAME=predictions

# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=false
FLASK_SECRET_KEY=your-secret-key-here-change-in-production

# Email Configuration (Flask-Mail)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@equipmentmonitoring.com

# Alert Configuration
ALERT_EMAIL_RECIPIENTS=admin@example.com,manager@example.com
ALERT_THRESHOLD=0.7

# System Configuration
MAINTENANCE_INTERVAL=30
LOG_LEVEL=INFO
MAX_PREDICTIONS_PER_DAY=1000

# Prediction Model Configuration
MODEL_CONFIDENCE_THRESHOLD=0.6
MODEL_UPDATE_FREQUENCY=7

# Database Backup Configuration
BACKUP_ENABLED=True
BACKUP_FREQUENCY=daily
BACKUP_RETENTION_DAYS=30

# Security Configuration
PASSWORD_MIN_LENGTH=8
SESSION_TIMEOUT=3600
MAX_LOGIN_ATTEMPTS=5
